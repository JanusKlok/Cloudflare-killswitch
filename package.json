    "test:watch": "vitest",
    "typecheck": "wrangler types && tsc --noEmit",
    "types": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.13.0",
    "@cloudflare/workers-types": "4.20260429.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wrangler": "4.84.0"
  }
}
